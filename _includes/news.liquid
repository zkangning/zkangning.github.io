<div class="news">
  {% if site.data.news != blank %}
    {% assign news = site.data.news %}
    {% assign news_size = news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td>
              {{ item.text | markdownify | remove: '<p>' | remove: '</p>' }}
              {% if item.links %}
                {% for link in item.links %}
                  {% if forloop.first %} {% else %} / {% endif %}
                  <a href="{{ link.url }}" target="_blank" rel="external nofollow noopener">{{ link.label }}</a>
                {% endfor %}
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
